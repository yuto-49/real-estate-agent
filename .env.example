# ============================================================================
# Production Platform
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-xxxxx           # Claude API (production agents)
TOMTOM_API_KEY=xxxxx                     # TomTom Maps (geocoding + neighborhood, free tier)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/realestate
ZILLOW_API_KEY=                          # Listings + comps (Bridge/RapidAPI)
ATTOM_API_KEY=                           # Property records (optional)
REDIS_URL=redis://localhost:6379/0
MIROFISH_API_URL=http://localhost:5001

# App config
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_DEAL_VALUE_AUTO=2000000
MIN_OFFER_PERCENT=0.50
MAX_COUNTER_ROUNDS=10

